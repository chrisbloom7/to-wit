#!/usr/bin/env bash
# uninstall — remove To Wit hook, database, and binary symlink
#
# Usage:
#   ./uninstall [<install-dir>]
#
# Default install directory: /usr/local/bin

set -euo pipefail

INSTALL_DIR="${1:-/usr/local/bin}"

if command -v towit &>/dev/null; then
  towit implode --install-dir "${INSTALL_DIR}"
else
  echo "Warning: towit not found in PATH — cannot run implode." >&2
  echo "You may need to manually remove:" >&2
  echo "  • The towit binary symlink from ${INSTALL_DIR}/" >&2
  echo "  • The stop hook from ~/.claude/settings.json" >&2
  echo "  • The data directory at ~/.towit/" >&2
fi
