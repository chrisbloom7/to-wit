#!/usr/bin/env bash
# claudecat — Claude Code conversation catalog
#
# Usage:
#   claudecat <subcommand> [options]
#
# Subcommands:
#   setup [--full | --hook]       Initialize database (--full also installs hook and runs backfill; --hook also installs hook)
#   search <terms...> [--or] [--all | --summary] [--all | --title] [--csv] [--folder <path>]
#   list [--csv] [--folder <path>] [--topic <name>]
#   resume [--force] <session-id> Resume a session in its original working directory
#   prune [--dry-run]             Remove entries whose transcripts no longer exist
#   export <session-id> [--format md|json] [--summarize]
#   export --topic <name> [--format md|json] [--summarize]
#   backfill [--dry-run] [--force] [--folder <path>]
#   install-hook                  Add claudecat stop hook to ~/.claude/settings.json
#   uninstall-hook                Remove claudecat stop hook from ~/.claude/settings.json
#   teardown [--yes]              Remove hook and delete database
#   implode [--yes] [--install-dir <dir>]
#                                 Full uninstall: remove hook, database, and binary symlink
#   stats
#   help

set -euo pipefail

# Resolve real script location, following symlinks (macOS readlink lacks -f)
_source="$0"
while [ -L "${_source}" ]; do
  _dir="$(cd -P "$(dirname "${_source}")" && pwd)"
  _source="$(readlink "${_source}")"
  [[ "${_source}" != /* ]] && _source="${_dir}/${_source}"
done
SCRIPT_DIR="$(cd -P "$(dirname "${_source}")" && pwd)"
unset _source _dir
HELPERS_DIR="$(cd "${SCRIPT_DIR}/../libexec/claudecat" && pwd)"

if ! command -v python3 &>/dev/null; then
  echo "Error: python3 is required but was not found in PATH." >&2
  echo "Install Python 3 and ensure it is available as 'python3'." >&2
  exit 1
fi

usage() {
  awk '/^[^#]/ { exit } /^#!/ { next } { sub(/^# ?/, ""); print }' "$0"
}

subcommand="${1:-}"

case "${subcommand}" in
  setup)
    shift
    _full=false
    _hook=false
    _setup_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --full) _full=true; shift ;;
        --hook) _hook=true; shift ;;
        *) _setup_args+=("$1"); shift ;;
      esac
    done
    python3 "${HELPERS_DIR}/claudecat_setup.py" "${_setup_args[@]+"${_setup_args[@]}"}" || exit $?
    if [[ "${_full}" == true || "${_hook}" == true ]]; then
      python3 "${HELPERS_DIR}/claudecat_install_hook.py" || exit $?
    fi
    if [[ "${_full}" == true ]]; then
      python3 "${HELPERS_DIR}/claudecat_backfill.py" || exit $?
    fi
    ;;
  search)
    shift
    python3 "${HELPERS_DIR}/claudecat_search.py" "$@" || exit $?
    ;;
  list)
    shift
    python3 "${HELPERS_DIR}/claudecat_list.py" "$@" || exit $?
    ;;
  resume)
    shift
    python3 "${HELPERS_DIR}/claudecat_resume.py" "$@" || exit $?
    ;;
  open)
    shift
    echo "Warning: 'open' is deprecated; use 'resume' instead." >&2
    python3 "${HELPERS_DIR}/claudecat_resume.py" "$@" || exit $?
    ;;
  prune)
    shift
    python3 "${HELPERS_DIR}/claudecat_prune.py" "$@" || exit $?
    ;;
  export)
    shift
    python3 "${HELPERS_DIR}/claudecat_export.py" "$@" || exit $?
    ;;
  backfill)
    shift
    python3 "${HELPERS_DIR}/claudecat_backfill.py" "$@" || exit $?
    ;;
  install-hook)
    shift
    python3 "${HELPERS_DIR}/claudecat_install_hook.py" "$@" || exit $?
    ;;
  uninstall-hook)
    shift
    python3 "${HELPERS_DIR}/claudecat_uninstall_hook.py" "$@" || exit $?
    ;;
  teardown)
    shift
    python3 "${HELPERS_DIR}/claudecat_teardown.py" "$@" || exit $?
    ;;
  implode)
    shift
    python3 "${HELPERS_DIR}/claudecat_implode.py" "$@" || exit $?
    ;;
  stats)
    shift
    python3 "${HELPERS_DIR}/claudecat_stats.py" "$@" || exit $?
    ;;
  help|--help|-h)
    usage
    ;;
  "")
    echo "Error: no subcommand given." >&2
    echo >&2
    usage >&2
    exit 1
    ;;
  *)
    echo "Error: unknown subcommand '${subcommand}'." >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
