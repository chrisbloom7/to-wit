#!/usr/bin/env bash
# install — link towit into PATH
#
# Usage:
#   ./install [<install-dir>]
#
# Default install directory: /usr/local/bin

set -euo pipefail

INSTALL_DIR="${1:-/usr/local/bin}"
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ ! -d "${INSTALL_DIR}" ]]; then
  echo "Error: install directory '${INSTALL_DIR}' does not exist." >&2
  exit 1
fi

ln -sf "${REPO_DIR}/bin/towit" "${INSTALL_DIR}/towit"
echo "Installed: towit → ${INSTALL_DIR}/towit"
